---
import { getCollection, render } from 'astro:content';
import PageLayout from '~/layouts/PageLayout.astro';
import LandingLayout from '~/layouts/LandingLayout.astro';
import BlockRenderer from '~/components/BlockRenderer.astro';

export async function getStaticPaths() {
  const pages = await getCollection('pages');
  return pages.map((entry) => ({
    params: { slug: entry.id === 'index' ? undefined : entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const data = entry.data;

const isPageBuilder = 'content_blocks' in data;
const Layout = data.layout === 'landing' ? LandingLayout : PageLayout;
const metadata = {
  title: data.title,
  ...data.metadata,
};
---

<Layout metadata={metadata}>
  {isPageBuilder ? (
    <div data-editable="array" data-prop="content_blocks">
      {data.content_blocks.map((block) => (
        <BlockRenderer block={block} />
      ))}
    </div>
  ) : (
    <section class="px-4 py-16 sm:px-6 mx-auto lg:px-8 lg:py-20 max-w-4xl">
      <h1
        class="font-bold font-heading text-4xl md:text-5xl leading-tighter tracking-tighter"
        data-editable="text"
        data-prop="title"
      >
        {data.title}
      </h1>
      <div
        class="mx-auto prose prose-lg max-w-4xl dark:prose-invert dark:prose-headings:text-slate-300 prose-md prose-headings:font-heading prose-headings:leading-tighter prose-headings:tracking-tighter prose-headings:font-bold prose-a:text-blue-600 dark:prose-a:text-blue-400 prose-img:rounded-md prose-img:shadow-lg mt-8"
        data-editable="text"
        data-type="block"
        data-prop="@content"
      >
        <Content />
      </div>
    </section>
  )}
</Layout>
