---
import Base from "@/layouts/Base.astro";
import { getListPage } from "@/lib/contentParser.astro";
import Banner from "@/partials/Banner.astro";
import CallToAction from "@/partials/CallToAction.astro";
import Features from "@/partials/Features.astro";
import Testimonial from "@/partials/Testimonial.astro";
import callToActionData from "@/data/call-to-action.json";
import testimonialData from "@/data/testimonial.json";

const homepage = await getListPage("pages", "index");
const data = homepage.data;
if (!("banner" in data)) throw new Error("Expected homepage schema");
const { title, description, meta_title, image, banner, features } = data;
---

<Base title={title} meta_title={meta_title} description={description} image={image}>
  <!-- Banner -->
  <editable-component data-component="banner" data-prop="banner">
    <Banner {...banner} />
  </editable-component>
  <!-- /Banner -->

  <!-- Features -->
  <editable-component data-component="features" data-prop="features">
    <Features features={features} />
  </editable-component>
  <!-- /Features -->

  <Testimonial testimonial={testimonialData} />
  <CallToAction call_to_action={callToActionData} />
</Base>
