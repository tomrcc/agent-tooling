---
import ImageMod from "@/components/ImageMod.astro";
import Base from "@/layouts/Base.astro";
import { getSinglePage } from "@/lib/contentParser.astro";
import { markdownify } from "@/lib/utils/textConverter";
import Banner from "@/partials/Banner.astro";
import CallToAction from "@/partials/CallToAction.astro";
import Features from "@/partials/Features.astro";
import PageHeader from "@/partials/PageHeader.astro";
import Testimonial from "@/partials/Testimonial.astro";
import callToActionData from "@/data/call-to-action.json";
import testimonialData from "@/data/testimonial.json";
import { render } from "astro:content";

export async function getStaticPaths() {
  const COLLECTION_FOLDER = "pages";
  const pages = await getSinglePage(COLLECTION_FOLDER);

  const paths = pages.map((page) => ({
    params: {
      regular: page.id,
    },
    props: { page },
  }));
  return paths;
}

const { page } = Astro.props;
const { title, meta_title, description, image } = page.data;

const isPageBuilder = "content_blocks" in page.data;
const heroContent = isPageBuilder ? (page.data as any).hero_content : null;
const contentBlocks = isPageBuilder ? (page.data as any).content_blocks : [];

const { Content } = await render(page);
---

<Base
  title={title}
  meta_title={meta_title}
  description={description}
  image={image}
>
  {isPageBuilder ? (
    <>
      <section class="section pt-14">
        <div class="container">
          <div class="row justify-center">
            <div class="lg:col-7 md:col-9 mb-8 text-center">
              <h1
                set:html={markdownify(title)}
                class="mb-4 text-h3 lg:text-h1"
                data-editable="text"
                data-prop="title"
              />
              {heroContent && (
                <p
                  set:html={markdownify(heroContent)}
                  class="mb-8"
                  data-editable="text"
                  data-prop="hero_content"
                />
              )}
            </div>
            {image && (
              <div class="col-12" data-editable="image" data-prop-src="image">
                <ImageMod
                  src={image}
                  height={380}
                  width={1200}
                  alt={title}
                  format="webp"
                />
              </div>
            )}
          </div>
        </div>
      </section>

      {contentBlocks.map((block: any) => {
        if (block._type === "banner") {
          return <Banner {...block} />;
        }
        if (block._type === "features") {
          return <Features {...block.items} />;
        }
        if (block._type === "rich_text") {
          return (
            <section class="section-sm">
              <div class="container">
                <div class="row justify-center">
                  <div class="lg:col-10">
                    <div class="content" set:html={markdownify(block.content, true)} />
                  </div>
                </div>
              </div>
            </section>
          );
        }
        if (block._type === "call_to_action") {
          return <CallToAction call_to_action={callToActionData} />;
        }
        if (block._type === "testimonial") {
          return <Testimonial testimonial={testimonialData} />;
        }
      })}
    </>
  ) : (
    <>
      <PageHeader title={title} />
      <section class="section-sm">
        <div class="container">
          <div class="row justify-center">
            <div class="lg:col-10">
              <div
                class="content"
                data-editable="text"
                data-type="block"
                data-prop="@content"
              >
                <Content />
              </div>
            </div>
          </div>
        </div>
      </section>
    </>
  )}
</Base>
