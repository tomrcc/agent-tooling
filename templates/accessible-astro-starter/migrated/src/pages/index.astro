---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import Hero from '@components/Hero.astro'
import Feature from '@components/Feature.astro'
import Counter from '@components/Counter.astro'
import ContentMedia from '@components/ContentMedia.astro'
import FaqItem from '@components/FaqItem.astro'
import FaqInfo from '@components/FaqInfo.astro'
import CommunityMember from '@components/CommunityMember.astro'
import FeaturedProjects from '@components/FeaturedProjects.astro'
import FeaturedPosts from '@components/FeaturedPosts.astro'
import { Accordion, AvatarGroup, Heading } from 'accessible-astro-components'
import { getEntry } from 'astro:content'
import { getTeamMember } from '@utils/team'

const page = await getEntry('pages', 'index')
if (!page) throw new Error('Homepage content not found at src/content/pages/index.md')
const data = page.data
if (!('hero' in data)) throw new Error('Homepage schema mismatch')

const resolvedMembers = data.community.members
  .map((name) => getTeamMember(name))
  .filter(Boolean)
---

<DefaultLayout title={data.title ?? 'Accessible Astro Starter'} useTitleTemplate={false}>
  <editable-component data-component="hero" data-prop="hero">
    <Hero {...data.hero} />
  </editable-component>
  <section class="my-64">
    <div class="container">
      <Heading level="h2" class="mb-8">Features</Heading>
      <div class="grid grid-cols-1 gap-12 md:grid-cols-2 lg:grid-cols-3" data-editable="array" data-prop="features">
        {data.features.map((feature, i) => (
          <div data-editable="array-item" data-component="feature" data-id={`feature-${i}`}>
            <Feature {...feature} />
          </div>
        ))}
      </div>
    </div>
  </section>
  <div data-editable="array" data-prop="content_sections">
    {data.content_sections.map((section, i) => (
      <div data-editable="array-item" data-component="content-media" data-id={`content-section-${i}`}>
        <ContentMedia {...section} />
      </div>
    ))}
  </div>
  <div id="featured-projects" style={data.show_featured_projects ? '' : 'display:none'}>
    <FeaturedProjects />
  </div>
  <div id="featured-posts" style={data.show_featured_posts ? '' : 'display:none'}>
    <FeaturedPosts />
  </div>
  {data.faq && (
    <section class="my-64">
      <div class="container grid grid-cols-1 gap-12 md:grid-cols-2">
        <editable-component data-component="faq-info" data-prop="faq">
          <FaqInfo {...data.faq} />
        </editable-component>
        <div class="space-content">
          <Accordion>
            <div data-editable="array" data-prop="faq.items">
              {data.faq.items.map((item, i) => (
                <div data-editable="array-item" data-component="faq-item" data-id={`faq-item-${i}`}>
                  <FaqItem {...item} open={i === 0} />
                </div>
              ))}
            </div>
          </Accordion>
        </div>
      </div>
    </section>
  )}
  {data.community && (
    <section class="my-64">
      <div class="space-content container">
        <Heading level="h2"><span data-editable="text" data-prop="community.title">{data.community.title}</span></Heading>
        <p class="text-2xl" data-editable="text" data-prop="community.description">{data.community.description}</p>
        <AvatarGroup display="grid" gridItemsSize="300px" gridGap="2rem">
          {resolvedMembers.map((member, i) => (
            <CommunityMember {...member} />
          ))}
        </AvatarGroup>
      </div>
    </section>
  )}
  <section class="mt-64 mb-32">
    <div class="container">
      <Heading level="h2" class="mb-16"><span data-editable="text" data-prop="counters_heading">{data.counters_heading ?? 'Impact in numbers'}</span></Heading>
      <div class="grid grid-cols-1 gap-12 sm:grid-cols-2 md:grid-cols-4" data-editable="array" data-prop="counters">
        {data.counters.map((counter, i) => (
          <div data-editable="array-item" data-component="counter" data-id={`counter-${i}`}>
            <Counter {...counter} />
          </div>
        ))}
      </div>
    </div>
  </section>
</DefaultLayout>

<script>
  function initCCToggle(cc) {
    cc.enableEvents();
  }
  document.addEventListener('cloudcannon:update', async (e) => {
    const data = await e.detail.CloudCannon.value();
    const projects = document.getElementById('featured-projects');
    const posts = document.getElementById('featured-posts');
    if (projects) projects.style.display = data.show_featured_projects === false ? 'none' : '';
    if (posts) posts.style.display = data.show_featured_posts === false ? 'none' : '';
  });
  if (window.CloudCannon) {
    initCCToggle(window.CloudCannon);
  } else {
    document.addEventListener('cloudcannon:load', (e) => initCCToggle(e.detail.CloudCannon));
  }
</script>

<style>
  .avatar {
    border: 1px solid var(--border-color-subtle);
    border-radius: var(--radius-md);
    padding: var(--space-s);
  }
</style>
