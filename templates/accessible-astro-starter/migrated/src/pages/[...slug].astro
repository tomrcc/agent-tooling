---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import { getCollection, render } from 'astro:content'
import type { CollectionEntry } from 'astro:content'

export async function getStaticPaths() {
  const pages = await getCollection('pages')
  return pages
    .filter((page) => page.id !== 'index')
    .map((page) => ({
      params: { slug: page.id },
      props: { page },
    }))
}

interface Props {
  page: CollectionEntry<'pages'>
}

const { page } = Astro.props
const { Content } = await render(page)
const data = page.data
---

<DefaultLayout title={data.title ?? ''} description={data.description ?? ''}>
  <article class="container my-12">
    <h1 class="mb-8 text-4xl font-bold">{data.title}</h1>
    <div class="space-content prose prose-lg max-w-none" data-editable="text" data-type="block" data-prop="@content">
      <Content />
    </div>
  </article>
</DefaultLayout>
