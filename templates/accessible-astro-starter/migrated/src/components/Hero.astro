---
import { Link } from 'accessible-astro-components'
import { Icon } from 'astro-icon/components'
import { Image } from 'astro:assets'

interface HeroButton {
  label: string
  href: string
  type?: string
  icon?: string | null
}

interface Props {
  title?: string
  gradient_text?: string
  image?: string
  src?: string
  buttons?: HeroButton[]
}

const props = Astro.props
const imgSrc = props.image ?? props.src ?? '/astronaut-hero-img.webp'
const buttons = props.buttons ?? []
const hasSlot = Astro.slots.has('default')
---

<section class="hero my-24">
  <div class="container">
    <div class="grid grid-cols-1 items-center gap-24 lg:grid-cols-2">
      <div class="flex flex-col items-center gap-8 md:items-start">
        <h1 class="text-center text-6xl md:text-left lg:text-8xl">
          {hasSlot ? (
            <slot><span class="text-gradient">Accessible</span> Starter for Astro</slot>
          ) : (
            <>
              {props.gradient_text && <span class="text-gradient" data-editable="text" data-prop="gradient_text">{props.gradient_text}</span>}
              {' '}
              {props.title && <span data-editable="text" data-prop="title">{props.title}</span>}
            </>
          )}
        </h1>
        {buttons.length > 0 && (
          <div class="flex flex-col gap-3 min-[500px]:flex-row">
            {buttons.map((button) => (
              <Link
                href={button.href}
                isButton
                type={button.type ?? 'primary'}
                animateOnHover
                animationType="boop"
              >
                {button.icon && <Icon aria-hidden="true" name={button.icon} size="1.5rem" />}
                {button.label}
              </Link>
            ))}
          </div>
        )}
      </div>
      <Image
        class="hidden lg:block"
        src={imgSrc}
        alt=""
        decoding="async"
        width={800}
        height={600}
        loading="eager"
      />
    </div>
  </div>
</section>

<style lang="scss">
  h1 {
    text-wrap: unset;
  }

  .text-gradient {
    background: linear-gradient(
      315deg,
      light-dark(var(--color-primary-300), var(--color-secondary-100)) 25%,
      light-dark(var(--color-secondary-300), var(--color-primary-200))
    );
    background-clip: border-box;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
</style>
