---
import Link from "./ui/link.astro";

interface Props {
  title: string;
  description: string;
  button: {
    label: string;
    link: string;
  };
}

const { title, description, button } = Astro.props;
---

<div
  class="bg-black p-8 md:px-20 md:py-20 mt-20 mx-auto max-w-5xl rounded-lg flex flex-col items-center text-center">
  <h2
    class="text-white text-4xl md:text-6xl tracking-tight"
    data-editable="text"
    data-prop="title">
    {title}
  </h2>
  <p
    class="text-slate-400 mt-4 text-lg md:text-xl"
    data-editable="text"
    data-prop="description">
    {description}
  </p>
  <div class="flex mt-5">
    <Link href={button.link} style="inverted">
      <span data-editable="text" data-prop="button.label">{button.label}</span>
    </Link>
  </div>
</div>
