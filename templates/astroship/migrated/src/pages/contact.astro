---
import { getEntry } from "astro:content";
import Contactform from "@/components/contactform.astro";
import Container from "@/components/container.astro";
import Sectionhead from "@/components/sectionhead.astro";
import Layout from "@/layouts/Layout.astro";
import { Icon } from "astro-icon/components";

const page = await getEntry("pages", "contact");
if (!page) throw new Error("Missing pages/contact.md");
const { title, description, heading, body_text, address, email, phone } = page.data;
---

<Layout title={title}>
  <Container>
    <Sectionhead>
      <span slot="title" data-editable="text" data-prop="title">{title}</span>
      <span slot="desc" data-editable="text" data-prop="description">{description}</span>
    </Sectionhead>

    <div class="grid md:grid-cols-2 gap-10 mx-auto max-w-4xl mt-16">
      <div>
        <h2
          class="font-medium text-2xl text-gray-800"
          data-editable="text"
          data-prop="heading">
          {heading}
        </h2>
        <p
          class="text-lg leading-relaxed text-slate-500 mt-3"
          data-editable="text"
          data-prop="body_text">
          {body_text}
        </p>
        <div class="mt-5">
          <div class="flex items-center mt-2 space-x-2 text-gray-600">
            <Icon class="text-gray-400 w-4 h-4" name="uil:map-marker" />
            <span data-editable="text" data-prop="address">{address}</span>
          </div><div class="flex items-center mt-2 space-x-2 text-gray-600">
            <Icon class="text-gray-400 w-4 h-4" name="uil:envelope" /><a
              href={`mailto:${email}`}
              ><span data-editable="text" data-prop="email">{email}</span></a
            >
          </div><div class="flex items-center mt-2 space-x-2 text-gray-600">
            <Icon class="text-gray-400 w-4 h-4" name="uil:phone" /><a
              href={`tel:${phone}`}><span data-editable="text" data-prop="phone">{phone}</span></a
            >
          </div>
        </div>
      </div>
      <div>
        <Contactform />
      </div>
    </div>
  </Container>
</Layout>
