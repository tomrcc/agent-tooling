---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";

export async function getStaticPaths() {
  const dedicatedRoutes = new Set(["index", "projects", "services", "cv"]);
  const pages = await getCollection("pages");
  return pages
    .filter((page) => !dedicatedRoutes.has(page.slug))
    .map((page) => ({
      params: { slug: page.slug === "index" ? undefined : page.slug },
      props: { page },
    }));
}

const { page } = Astro.props;
const { Content } = await page.render();
const data = page.data;
---

<BaseLayout title={data.title} sideBarActiveItemID={data.sidebar_id}>
  {data._schema === "card_listing" && data.sections && (
    <div data-editable="array" data-prop="sections">
      {data.sections.map((section, sectionIdx) => (
        <div data-editable="array-item" class={sectionIdx > 0 ? "mt-10" : ""}>
          {section.heading && <div class="text-3xl w-full font-bold mb-5" data-editable="text" data-prop="heading">{section.heading}</div>}

          <div data-editable="array" data-prop="items">
            {section.items.map((item, i) => (
              <div data-editable="array-item">
                <HorizontalCard
                  title={item.title}
                  img={item.img}
                  desc={item.desc}
                  url={item.url}
                  badge={item.badge}
                />
                {i < section.items.length - 1 && <div class="divider my-0" />}
              </div>
            ))}
            <template>
              <div data-editable="array-item">
                <div class="rounded-lg bg-base-100">
                  <div class="hero-content flex-col md:flex-row">
                    <div class="grow w-full">
                      <h1 class="text-xl font-bold">
                        <span data-editable="text" data-prop="title"></span>
                      </h1>
                      <p class="py-1 text-1xl" data-editable="text" data-prop="desc"></p>
                    </div>
                  </div>
                </div>
              </div>
            </template>
          </div>
        </div>
      ))}
      <template>
        <div data-editable="array-item">
          <div class="text-3xl w-full font-bold mb-5" data-editable="text" data-prop="heading"></div>
          <div data-editable="array" data-prop="items">
            <template>
              <div data-editable="array-item">
                <div class="rounded-lg bg-base-100">
                  <div class="hero-content flex-col md:flex-row">
                    <div class="grow w-full">
                      <h1 class="text-xl font-bold">
                        <span data-editable="text" data-prop="title"></span>
                      </h1>
                      <p class="py-1 text-1xl" data-editable="text" data-prop="desc"></p>
                    </div>
                  </div>
                </div>
              </div>
            </template>
          </div>
        </div>
      </template>
    </div>
  )}

  {(!data._schema || data._schema === "default") && (
    <article class="prose prose-lg max-w-[750px]">
      <Content />
    </article>
  )}
</BaseLayout>
